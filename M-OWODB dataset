l = ET.SubElement(annotation_el, 'object')\n","            ET.SubElement(object_el, 'name').text = coco_instance.cats[annotation['category_id']]['name']\n","            ET.SubElement(object_el, 'difficult').text = '0'\n","            bb_el = ET.SubElement(object_el, 'bndbox')\n","            ET.SubElement(bb_el, 'xmin').text = str(int(annotation['bbox'][0] + 1.0))\n","            ET.SubElement(bb_el, 'ymin').text = str(int(annotation['bbox'][1] + 1.0))\n","            ET.SubElement(bb_el, 'xmax').text = str(int(annotation['bbox'][0] + annotation['bbox'][2] + 1.0))\n","            ET.SubElement(bb_el, 'ymax').text = str(int(annotation['bbox'][1] + annotation['bbox'][3] + 1.0))\n","        xml_name = image_details['file_name'].split('.')[0] + '.xml'\n","        ET.ElementTree(annotation_el).write(os.path.join(ann_dst, xml_name))\n","\n","coco_to_voc_xml('/content/drive/MyDrive/coco2017/annotations/instances_val2017.json', ann_dst, coco_val_needed)\n","coco_to_voc_xml('/content/drive/MyDrive/coco2017/annotations/instances_train2017.json', ann_dst, coco_train_needed)\n","print(\"COCO XML 변환 완료!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"PT0hBA0mvX3Y","executionInfo":{"status":"ok","timestamp":1779725424684,"user_tz":-540,"elapsed":37585,"user":{"displayName":"안세현","userId":"18405910476867878873"}},"outputId":"4a714c4c-4642-4a75-eda3-3543d81cce5c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["loading annotations into memory...\n","Done (t=0.61s)\n","creating index...\n","index created!\n"]},{"output_type":"stream","name":"stderr","text":["XML 변환: 100%|██████████| 4952/4952 [00:06<00:00, 717.70it/s]\n"]},{"output_type":"stream","name":"stdout","text":["loading annotations into memory...\n","Done (t=19.25s)\n","creating index...\n","index created!\n"]},{"output_type":"stream","name":"stderr","text":["XML 변환: 100%|██████████| 117266/117266 [00:00<00:00, 1401667.28it/s]\n"]},{"output_type":"stream","name":"stdo